rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // المستخدمون يقرؤون ويكتبون بياناتهم فقط (يشمل كل ما تحتهم: trips, وغيرها)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subCollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // أي مسار آخر غير متوقّع: مرفوض افتراضياً (لا يوجد catch-all مفتوح)
  }
}
