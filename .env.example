PORT=3000

# ── AI engines ────────────────────────────────────────────────────────────
# Groq is the PRIMARY engine (free key: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
# Optional: override the Groq model (default: openai/gpt-oss-20b)
# GROQ_MODEL=openai/gpt-oss-20b
# Gemini is used automatically as a fallback if Groq fails
GEMINI_API_KEY=your_google_gemini_api_key_here

# ── Place verification & destination resolution ───────────────────────────
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── Optional media / weather ──────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here   # من unsplash.com/developers (مجاني)
PEXELS_API_KEY=your_pexels_api_key_here             # من pexels.com/api (مجاني)
OPENWEATHER_API_KEY=your_openweather_api_key_here   # من openweathermap.org (مجاني)
